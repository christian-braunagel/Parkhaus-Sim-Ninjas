CC = gcc
CFLAGS = -Wall -Wextra -I./include
SRC_DIR = src
OBJ_DIR = obj

# Liste aller benötigten Quelldateien für die Test-Executable
TEST_SRC = $(SRC_DIR)/functions_test_file.c \
           $(SRC_DIR)/queue.c \
           $(SRC_DIR)/parkhaus.c \
           $(SRC_DIR)/statistics.c \
           $(SRC_DIR)/sim_parameters.c

# Erzeuge Objektdateinamen aus Quelldateinamen im OBJ_DIR
TEST_OBJ = $(TEST_SRC:$(SRC_DIR)/%.c=$(OBJ_DIR)/%.o)

TARGET = functions_test

# Standard-Ziel: Erstellt das Test-Programm
all: $(OBJ_DIR) $(TARGET)

$(TARGET): $(TEST_OBJ)
	$(CC) $(CFLAGS) -o $@ $^

# Regel zum Kompilieren der .c Dateien zu .o Dateien
$(OBJ_DIR)/%.o: $(SRC_DIR)/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# Erstelle das Verzeichnis für Objektdateien, falls es nicht existiert
$(OBJ_DIR):
	mkdir -p $(OBJ_DIR)

# Bereinigung
clean:
	rm -rf $(OBJ_DIR) $(TARGET)

.PHONY: all clean
